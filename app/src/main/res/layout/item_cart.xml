<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="16dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp">

    <!-- Name + Price -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvCartName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Product Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tvCartPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0/kg"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/price_badge_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

    </LinearLayout>

    <!-- Quantity Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quantity (kg):"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginEnd="12dp"/>

        <!-- Minus Button -->
        <TextView
            android:id="@+id/btnMinus"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="−"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/qty_btn_bg"/>

        <!-- Quantity Number -->
        <TextView
            android:id="@+id/tvCartQuantity"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"/>

        <!-- Plus Button -->
        <TextView
            android:id="@+id/btnPlus"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="+"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/qty_btn_bg"/>

    </LinearLayout>

    <!-- Subtotal -->
    <TextView
        android:id="@+id/tvCartSubtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subtotal: ₹0"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="12dp"/>

    <!-- Remove Button -->
    <Button
        android:id="@+id/btnRemoveCart"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="🗑️ Remove"
        android:backgroundTint="#B00020"
        android:textColor="#FFFFFF"
        android:textSize="13sp"/>

</LinearLayout>